# ===================
# Application
# ===================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=YYD.AI

# ===================
# Supabase
# ===================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================
# Alibaba Cloud
# ===================
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_REGION=cn-hangzhou

# IQS (Search)
ALIYUN_IQS_ENDPOINT=https://iqs.cn-hangzhou.aliyuncs.com
ALIYUN_IQS_APP_KEY=your-app-key

# OSS (Storage)
ALIYUN_OSS_BUCKET=yyd-ai-storage
ALIYUN_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_CDN_URL=https://cdn.yyd.ai

# Qwen-TTS (Voice)
ALIYUN_QWEN_TTS_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/audio/tts
ALIYUN_QWEN_TTS_MODEL=cosyvoice-v1

# ===================
# Stripe
# ===================
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret

# Stripe Product IDs
STRIPE_PRO_PRICE_ID=price_xxx
STRIPE_CREDITS_100_PRICE_ID=price_xxx
STRIPE_CREDITS_500_PRICE_ID=price_xxx
STRIPE_CREDITS_1000_PRICE_ID=price_xxx

# ===================
# Upstash Redis (Rate Limiting)
# ===================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ===================
# OAuth Providers
# ===================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret